---
import GitHub from "./icons/GitHub.astro";
import Php from "./icons/Php.astro";
import Tailwind from "./icons/Tailwind.astro";
import Link from "./icons/Link.astro";
import LinkButton from "./LinkButton.astro";
import NextJS from "./icons/NextJS.astro";
import JavaScript from "./icons/JavaScript.astro";
import Mustache from "./icons/Mustache.astro";
import Supabase from "./icons/Supabase.astro";
import Python from "./icons/Python.astro";
import Firebase from "./icons/Firebase.astro";
import ReactIcon from "./icons/React.astro";
import AstroIcon from "./icons/AstroIcon.astro";

const TAGS = {
  PHP: {
    name: "PHP",
    class: "bg-[#734f96] text-white",
    icon: Php,
  },
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },

  JAVASCRIPT: {
    name: "JavaScript",
    class: "bg-[#f0db4f]/90 text-black",
    icon: JavaScript,
  },
  MUSTACHE: {
    name: "Mustache",
    class: "bg-gray-100/80 text-black",
    icon: Mustache,
  },
  SUPABASE: {
    name: "Supabase",
    class: "bg-[#121212] text-white",
    icon: Supabase,
  },
  PYTHON: {
    name: "Python",
    class: "bg-[#003159] text-white",
    icon: Python,
  },
  FIREBASE: {
    name: "Firebase",
    class: "bg-[#ffca28]/60 text-zinc-900",
    icon: Firebase,
  },
  REACT: {
    name: "React",
    class: "bg-[#003159]/90 text-white",
    icon: ReactIcon,
  },
  ASTROICON: {
    name: "Astro",
    class: "bg-[#23262F]/80 text-white",
    icon: AstroIcon,
  },
};
const PROJECTS = [
  {
    slug: "tools-cla",
    title: "CLA Tools - Colección de herramientas Web",
    description:
      "Herramienta gratuita y de código abierto pensada para acelerar la carga de actividades y reducir procesos repetitivos, brindando una experiencia más fluida.",
    link: "https://tools.claangel.site/",
    github: "https://github.com/AngelCLA/CLA-Tools",
    image: "https://images.claangel.site/tools-cla/tools-cla.png",
    tags: [TAGS.ASTROICON, TAGS.TAILWIND, TAGS.JAVASCRIPT],
  },
  {
    slug: "edi-upmys",
    title: "EDI-UPMYS - Plataforma para la evaluación de conocimientos",
    description:
      "Plataforma integral para evaluar conocimientos y habilidades académicas dentro de la Universidad Politécnica del Mar y la Sierra, diseñada para ofrecer una experiencia clara, fluida y eficiente tanto para estudiantes como para profesores.",
    link: "https://edi.upmys.edu.mx/",
    image: "/projects/edi-upmys/edi.png",
    tags: [TAGS.PHP, TAGS.TAILWIND, TAGS.MUSTACHE, TAGS.JAVASCRIPT],
  },

  {
    slug: "cla-kahoot",
    title: "CLA Kahoot – Generador de cuestionarios Kahoot",
    description:
      "Aplicación web SPA para generar y ejecutar quizzes educativos interactivos en tiempo real, inspirados en Kahoot!, usando React, Firebase/Firestore y Tailwind CSS.",
    link: "https://kahoot.claangel.site/",
    github: "https://github.com/AngelCLA/CLA-Kahoot",
    image: "https://images.claangel.site/cla-kahoot/CLA-Kahoot.png",
    tags: [TAGS.REACT, TAGS.FIREBASE, TAGS.TAILWIND],
  },
  {
    slug: "tf-clinica",
    title: "TF-Clinica - Sistema de gestión para clínica de fisioterapia",
    description:
      "Plataforma integral para la gestión operativa de la clínica de fisioterapia de la Universidad Politécnica del Mar y la Sierra, optimizada para mejorar la organización, el seguimiento clínico y la atención al usuario.",
    link: "https://tf-clinica.netlify.app/",
    image: "https://www.claangel.site/projects/tf-clinica/TF-Clinica.png",
    tags: [TAGS.PHP, TAGS.TAILWIND, TAGS.JAVASCRIPT, TAGS.SUPABASE],
  },
  {
    slug: "cla-winconfig",
    title: "CLA WinConfig – Automatización de PCs con Windows",
    description:
      "Herramienta open source para automatizar y estandarizar la configuración de PCs con Windows en centros de cómputo educativos, reduciendo tiempos de preparación y errores humanos.",
    link: "https://cla-winconfig.claangel.site/",
    github: "https://github.com/AngelCLA/CLA-WinConfig",
    image: "https://images.claangel.site/cla-winconfig/CLA-WinConfig.png",
    tags: [TAGS.PYTHON],
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
  {
    PROJECTS.map(({ slug, image, title, description, tags, link, github }) => (
      <article class="flex flex-col h-full rounded-xl overflow-hidden shadow-xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50 transition duration-300 ease-in-out hover:shadow-2xl group">
        <a href={`/projects/${slug}`} class="flex flex-col flex-grow">
          {/* Imagen */}
          <div class="flex-shrink-0 overflow-hidden h-48 md:h-56">
            <img
              alt={title}
              class="w-full h-full object-cover object-top transition duration-500 group-hover:scale-105"
              loading="lazy"
              src={image}
            />
          </div>

          {/* Contenido */}
          <div class="flex flex-col flex-grow p-6 gap-4">
            {/* Título */}
            <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100 group-hover:text-purple-600 dark:group-hover:text-purple-400 transition-colors line-clamp-2">
              {title}
            </h3>

            {/* Tags */}
            <ul class="flex flex-row flex-wrap gap-2">
              {tags.map((tag) => (
                <li>
                  <span
                    class={`flex gap-x-1 rounded-full text-xs ${tag.class} py-1 px-2 w-fit`}
                  >
                    <tag.icon class="size-3.5" />
                    {tag.name}
                  </span>
                </li>
              ))}
            </ul>

            {/* Descripción */}
            <p class="text-sm text-gray-700 dark:text-gray-400 flex-grow line-clamp-3">
              {description}
            </p>
          </div>
        </a>

        {/* Botones */}
        <footer class="flex items-center justify-start gap-3 pt-4 px-6 pb-4 border-t border-gray-200 dark:border-gray-700">
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-5" />
              Code
            </LinkButton>
          )}
          {link && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Preview
            </LinkButton>
          )}
        </footer>
      </article>
    ))
  }
</div>
