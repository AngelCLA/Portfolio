---
import Layout from "@/layouts/Layout.astro";
import SectionContainer from "@/components/SectionContainer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Link from "@/components/icons/Link.astro";
import GitHub from "@/components/icons/GitHub.astro";
import ReactIcon from "@/components/icons/React.astro";
import Firebase from "@/components/icons/Firebase.astro";
import Tailwind from "@/components/icons/Tailwind.astro";
import ProjectGallery from "@/components/ProjectGallery.astro";

const project = {
  title: "CLA-Kahoot",
  titleSuffix: "Plataforma de cuestionarios interactivos en tiempo real",
  subtitle:
    "Arquitectura serverless orientada a sesiones concurrentes, sincronización de estado y gamificación educativa — construida con React, Firebase y Tailwind CSS.",
  description:
    "Aplicación web desarrollada con React, Firebase y Tailwind CSS para crear y ejecutar cuestionarios interactivos en tiempo real.",
  link: "https://kahoot.claangel.site/",
  link2: "https://github.com/AngelCLA/CLA-Kahoot",
  images: [
    "https://images.claangel.site/cla-kahoot/CLA-Kahoot-1.png",
    "https://images.claangel.site/cla-kahoot/CLA-Kahoot-2.png",
    "https://images.claangel.site/cla-kahoot/CLA-Kahoot-3.png",
    "https://images.claangel.site/cla-kahoot/CLA-Kahoot-4.png",
  ],
  tags: [
    { name: "React", class: "bg-[#003159]/90 text-white", icon: ReactIcon },
    {
      name: "Firebase",
      class: "bg-[#ffca28]/60 text-zinc-900",
      icon: Firebase,
    },
    {
      name: "Tailwind CSS",
      class: "bg-[#003159]/70 text-white",
      icon: Tailwind,
    },
  ],
  stats: [
    { value: "< 200ms", label: "Latencia de sincronización" },
    { value: "Serverless", label: "Infraestructura BaaS" },
    { value: "Multi-client", label: "Sesiones concurrentes" },
  ],
};
---

<style>
  /* ── Microinteracciones sutiles ── */
  .card-lift {
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }
  .card-lift:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px -6px rgba(147, 51, 234, 0.12);
  }

  .section-number {
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.03em;
  }

  .divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      currentColor 20%,
      currentColor 80%,
      transparent
    );
    opacity: 0.1;
  }

  .accent-left {
    border-left: 2px solid rgba(147, 51, 234, 0.35);
  }

  .tag-item {
    transition: opacity 0.18s ease;
  }
  .tag-item:hover {
    opacity: 0.8;
  }

  /* Subtle underline on back link */
  .back-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .back-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 0.2s ease;
  }
  .back-link:hover::after {
    width: 100%;
  }

  /* Staggered entry animation */
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .fade-up {
    animation: fadeUp 0.5s ease both;
  }
  .delay-1 {
    animation-delay: 0.08s;
  }
  .delay-2 {
    animation-delay: 0.16s;
  }
  .delay-3 {
    animation-delay: 0.24s;
  }
  .delay-4 {
    animation-delay: 0.32s;
  }
</style>

<Layout
  title={`${project.title} – Proyecto de CLAAngel`}
  description={project.description}
>
  <main class="px-4">
    <SectionContainer class="py-26 md:py-20">
      <!-- ── BACK NAVIGATION ── -->
      <div class="max-w-4xl mx-auto mb-12 fade-up">
        <a
          href="javascript:history.back()"
          class="back-link text-sm text-gray-500 dark:text-gray-500 hover:text-purple-600 dark:hover:text-purple-400 transition-colors"
        >
          ← Proyectos
        </a>
      </div>

      <article class="max-w-4xl mx-auto">
        <!-- ══════════════════════════════════════
             HEADER — Jerarquía editorial clara
        ══════════════════════════════════════ -->
        <header class="mb-6 fade-up delay-1">
          <!-- Eyebrow / categoría -->
          <p
            class="text-xs font-semibold tracking-widest uppercase text-purple-500 dark:text-purple-400 mb-4"
          >
            Proyecto personal · Frontend + Real-time
          </p>

          <!-- Título principal: peso máximo -->
          <h1
            class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-gray-100 leading-none tracking-tight mb-5"
          >
            {project.title}
          </h1>

          <!-- Subtítulo descriptivo con más peso y claridad -->
          <p
            class="text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed mb-8"
          >
            {project.subtitle}
          </p>

          <!-- Tags con más separación y presencia -->
          <ul class="flex flex-wrap gap-3 mb-10" role="list">
            {
              project.tags.map((tag) => (
                <li>
                  <span
                    class={`tag-item flex gap-x-2 items-center rounded-full text-xs font-medium ${tag.class} py-2 px-4`}
                  >
                    <tag.icon className="size-3.5" />
                    {tag.name}
                  </span>
                </li>
              ))
            }
          </ul>
        </header>

        <!-- ══════════════════════════════════════
             GALLERY
        ══════════════════════════════════════ -->
        <div class="fade-up delay-2 mb-8">
          <ProjectGallery images={project.images} title={project.title} />
        </div>

        <!-- ── CTAs — banda contenida, no flotando ── -->
        <div
          class="flex w-full items-center justify-center gap-4 mb-8 p-6 rounded-2xl bg-gray-50 dark:bg-gray-800/20 fade-up delay-3"
        >
          <LinkButton href={project.link}>
            <Link class="size-4" />
            Ver demo en vivo
          </LinkButton>
          <LinkButton href={project.link2} variant="secondary">
            <GitHub class="size-4" />
            Ver código fuente
          </LinkButton>
        </div>
        <!-- ══════════════════════════════════════
             CONTENIDO — Layout editorial
        ══════════════════════════════════════ -->
        <div class="space-y-14 fade-up delay-4">
          <!-- ── 01 · CONTEXTO ── -->
          <section>
            <div class="flex items-baseline gap-4 mb-6">
              <span
                class="section-number text-4xl font-bold text-gray-200 dark:text-gray-800 select-none"
                >01</span
              >
              <h2
                class="text-2xl font-bold text-purple-600 dark:text-purple-500"
              >
                Contexto y objetivo
              </h2>
            </div>
            <div
              class="accent-left pl-6 space-y-4 text-gray-700 dark:text-gray-300 leading-relaxed"
            >
              <p>
                CLA-Kahoot es una SPA diseñada para orquestar cuestionarios
                interactivos en tiempo real con múltiples participantes
                simultáneos. El desafío central fue construir una arquitectura
                capaz de garantizar consistencia de estado global,
                sincronización inmediata entre clientes y cálculo determinístico
                de resultados — todo sobre infraestructura serverless, sin un
                servidor propio.
              </p>
              <p>
                El proyecto demuestra capacidad de toma de decisiones técnicas
                bajo restricciones reales: optimización de lecturas en NoSQL,
                control de suscripciones para evitar memory leaks y separación
                explícita entre estado efímero de sesión y datos persistentes.
              </p>
            </div>
          </section>

          <div class="divider text-gray-400 dark:text-gray-700"></div>

          <!-- ── 02 · ARQUITECTURA ── -->
          <section>
            <div class="flex items-baseline gap-4 mb-8">
              <span
                class="section-number text-4xl font-bold text-gray-200 dark:text-gray-800 select-none"
                >02</span
              >
              <h2
                class="text-2xl font-bold text-purple-600 dark:text-purple-500"
              >
                Arquitectura del sistema
              </h2>
            </div>

            <!-- Grid asimétrico: 2+2 + 1 full -->
            <div class="grid md:grid-cols-2 gap-4 mb-4">
              <div
                class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl accent-left pl-7"
              >
                <h4
                  class="font-semibold text-purple-500 dark:text-purple-400 mb-2 text-sm uppercase tracking-wide"
                >
                  Frontend SPA
                </h4>
                <p
                  class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"
                >
                  Aplicación React bajo arquitectura Single Page Application con
                  componentes reutilizables y separación explícita de
                  responsabilidades por dominio funcional.
                </p>
              </div>
              <div
                class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl accent-left pl-7"
              >
                <h4
                  class="font-semibold text-purple-500 dark:text-purple-400 mb-2 text-sm uppercase tracking-wide"
                >
                  Gestión de estado
                </h4>
                <p
                  class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"
                >
                  Control determinístico del estado de sesión, temporizador,
                  progreso y ranking — gestionado en cliente con flujos
                  predecibles y sin efectos secundarios no controlados.
                </p>
              </div>
              <div
                class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl accent-left pl-7"
              >
                <h4
                  class="font-semibold text-purple-500 dark:text-purple-400 mb-2 text-sm uppercase tracking-wide"
                >
                  Persistencia NoSQL
                </h4>
                <p
                  class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"
                >
                  Firestore estructurado por sesiones activas, preguntas y
                  respuestas. Diseño de colecciones orientado a minimizar
                  lecturas facturadas y mantener coherencia entre nodos.
                </p>
              </div>
              <div
                class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl accent-left pl-7"
              >
                <h4
                  class="font-semibold text-purple-500 dark:text-purple-400 mb-2 text-sm uppercase tracking-wide"
                >
                  Sincronización en tiempo real
                </h4>
                <p
                  class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"
                >
                  Listeners activos con suscripciones controladas y cleanup
                  explícito, garantizando consistencia de estado entre todos los
                  clientes conectados a una misma sesión.
                </p>
              </div>
            </div>

            <!-- Highlight card full-width -->
            <div
              class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl border border-purple-500/15"
            >
              <p
                class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed"
              >
                <span class="font-semibold text-purple-500 dark:text-purple-400"
                  >Infraestructura:</span
                >{" "}
                Firebase actúa como Backend as a Service completo, eliminando la necesidad
                de servidor propio y habilitando escalabilidad automática bajo un
                modelo serverless — ideal para proyectos con demanda variable y despliegue
                ágil.
              </p>
            </div>
          </section>

          <div class="divider text-gray-400 dark:text-gray-700"></div>

          <!-- ── 03 · RETOS TÉCNICOS ── -->
          <section>
            <div class="flex items-baseline gap-4 mb-8">
              <span
                class="section-number text-4xl font-bold text-gray-200 dark:text-gray-800 select-none"
                >03</span
              >
              <h2
                class="text-2xl font-bold text-purple-600 dark:text-purple-500"
              >
                Retos técnicos resueltos
              </h2>
            </div>
            <div class="grid md:grid-cols-2 gap-4">
              {
                [
                  {
                    title: "Sincronización multiusuario consistente",
                    body: "Listeners en tiempo real con control de suscripciones y cleanup explícito para prevenir memory leaks y divergencias de estado entre clientes concurrentes.",
                  },
                  {
                    title: "Gestión de estado complejo",
                    body: "Temporizador y transición entre preguntas con control determinístico, evitando race conditions en entornos multi-cliente donde el orden de eventos no está garantizado.",
                  },
                  {
                    title: "Modelo de datos optimizado en NoSQL",
                    body: "Arquitectura de colecciones en Firestore diseñada para minimizar lecturas facturadas, reducir latencia y mantener coherencia entre sesiones activas y resultados finales.",
                  },
                  {
                    title: "Ranking dinámico confiable",
                    body: "Cálculo reactivo basado en exactitud y tiempo de respuesta con actualizaciones en tiempo real — consistente bajo condiciones de concurrencia y reconexiones parciales.",
                  },
                ].map((item) => (
                  <div class="card-lift p-6 bg-gray-100 dark:bg-gray-800/20 rounded-2xl">
                    <h4 class="font-semibold text-purple-500 dark:text-purple-400 mb-3 text-sm">
                      {item.title}
                    </h4>
                    <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                      {item.body}
                    </p>
                  </div>
                ))
              }
            </div>
          </section>

          <div class="divider text-gray-400 dark:text-gray-700"></div>

          <!-- ── 04 · DECISIONES TÉCNICAS ── -->
          <section>
            <div class="flex items-baseline gap-4 mb-8">
              <span
                class="section-number text-4xl font-bold text-gray-200 dark:text-gray-800 select-none"
                >04</span
              >
              <h2
                class="text-2xl font-bold text-purple-600 dark:text-purple-500"
              >
                Decisiones técnicas clave
              </h2>
            </div>

            <!-- Grid 2-col con items más densos y significativos -->
            <div class="grid md:grid-cols-2 gap-4">
              {
                [
                  "Firebase como BaaS acelera el ciclo de desarrollo sin sacrificar escalabilidad ni observabilidad del sistema.",
                  "Centralización de lógica crítica en cliente con validaciones estructuradas, reduciendo dependencia de operaciones de escritura en Firestore.",
                  "Separación explícita entre estado efímero de sesión (volátil) y datos persistentes (durables) para simplificar el modelo mental del sistema.",
                  "Componentización orientada a mantenibilidad y reutilización: cada componente tiene una única responsabilidad y superficie de cambio acotada.",
                ].map((text) => (
                  <div class="card-lift flex gap-3 p-5 bg-gray-100 dark:bg-gray-800/20 rounded-2xl items-start">
                    <span class="mt-1 flex-shrink-0 w-1.5 h-1.5 rounded-full bg-purple-500 opacity-70" />
                    <p class="text-gray-700 dark:text-gray-300 text-sm leading-relaxed">
                      {text}
                    </p>
                  </div>
                ))
              }
            </div>
          </section>

          <div class="divider text-gray-400 dark:text-gray-700"></div>

          <!-- ── 05 · CONSIDERACIONES + CAPACIDADES (side by side) ── -->
          <section>
            <div class="grid md:grid-cols-2 gap-x-12 gap-y-10">
              <!-- Consideraciones técnicas -->
              <div>
                <div class="flex items-baseline gap-3 mb-6">
                  <span
                    class="section-number text-3xl font-bold text-gray-200 dark:text-gray-800 select-none"
                    >05</span
                  >
                  <h2
                    class="text-xl font-bold text-purple-600 dark:text-purple-500"
                  >
                    Consideraciones técnicas
                  </h2>
                </div>
                <ul class="space-y-3">
                  {
                    [
                      "Manejo de reconexión de clientes en sesiones activas",
                      "Control de suscripciones para evitar listeners duplicados",
                      "Validación de datos antes de toda escritura en base de datos",
                      "Reglas de seguridad definidas en Firestore",
                      "Diseño responsivo adaptable a móvil y escritorio",
                      "Estructura preparada para escalar a nuevas funcionalidades",
                    ].map((item) => (
                      <li class="flex gap-3 items-start text-sm text-gray-700 dark:text-gray-300">
                        <span class="mt-1.5 flex-shrink-0 w-1 h-1 rounded-full bg-purple-400 opacity-60" />
                        {item}
                      </li>
                    ))
                  }
                </ul>
              </div>

              <!-- Capacidades demostradas -->
              <div>
                <div class="flex items-baseline gap-3 mb-6">
                  <span
                    class="section-number text-3xl font-bold text-gray-200 dark:text-gray-800 select-none"
                    >06</span
                  >
                  <h2
                    class="text-xl font-bold text-purple-600 dark:text-purple-500"
                  >
                    Capacidades demostradas
                  </h2>
                </div>
                <ul class="space-y-3">
                  {
                    [
                      "Diseño de arquitecturas frontend desacopladas",
                      "Implementación de sistemas en tiempo real",
                      "Manejo de estado complejo en aplicaciones SPA",
                      "Integración eficiente con servicios serverless",
                      "Desarrollo y despliegue autónomo de productos completos",
                      "Estructuración de proyectos con visión de escalabilidad",
                    ].map((item) => (
                      <li class="flex gap-3 items-start text-sm text-gray-700 dark:text-gray-300">
                        <span class="mt-1.5 flex-shrink-0 w-1 h-1 rounded-full bg-purple-400 opacity-60" />
                        {item}
                      </li>
                    ))
                  }
                </ul>
              </div>
            </div>
          </section>

          <div class="divider text-gray-400 dark:text-gray-700"></div>

          <!-- ── 07 · STACK TÉCNICO ── -->
          <section>
            <div class="flex items-baseline gap-4 mb-8">
              <span
                class="section-number text-4xl font-bold text-gray-200 dark:text-gray-800 select-none"
                >07</span
              >
              <h2
                class="text-2xl font-bold text-purple-600 dark:text-purple-500"
              >
                Stack técnico
              </h2>
            </div>

            <!-- Grid 4-col para tech — más compacto y visual -->
            <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4">
              {
                [
                  {
                    name: "React",
                    desc: "Componentización y renderizado eficiente mediante arquitectura SPA declarativa.",
                  },
                  {
                    name: "Firebase / Firestore",
                    desc: "Persistencia NoSQL y sincronización en tiempo real bajo modelo serverless.",
                  },
                  {
                    name: "Tailwind CSS",
                    desc: "Sistema de diseño utility-first para interfaces responsivas y consistentes.",
                  },
                  {
                    name: "Arquitectura SPA",
                    desc: "Separación de responsabilidades con flujo de datos unidireccional.",
                  },
                ].map((tech) => (
                  <div class="card-lift p-5 bg-gray-100 dark:bg-gray-800/20 rounded-2xl border-t-2 border-purple-500/20">
                    <p class="font-bold text-gray-900 dark:text-gray-100 mb-2 text-sm">
                      {tech.name}
                    </p>
                    <p class="text-xs text-gray-600 dark:text-gray-400 leading-relaxed">
                      {tech.desc}
                    </p>
                  </div>
                ))
              }
            </div>
          </section>
        </div>
        <!-- /content -->

        <!-- ── BOTTOM CTA ── -->
        <div
          class="mt-24 pt-10 border-t border-gray-200 dark:border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-6"
        >
          <div>
            <p class="text-sm text-gray-500 dark:text-gray-500">
              ¿Quieres ver más proyectos?
            </p>
            <a
              href="javascript:history.back()"
              class="back-link text-purple-600 dark:text-purple-400 font-semibold hover:opacity-80 transition-opacity"
            >
              ← Volver al portafolio
            </a>
          </div>
          <div class="flex gap-3">
            <LinkButton href={project.link}>
              <Link class="size-4" />
              Ver demo
            </LinkButton>
            <LinkButton href={project.link2} variant="secondary">
              <GitHub class="size-4" />
              GitHub
            </LinkButton>
          </div>
        </div>
      </article>
    </SectionContainer>
  </main>
</Layout>
